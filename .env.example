# Polyphemus configuration — copy to .env and adjust.
# The offline demo and test suite run entirely in mock mode; no AWS account needed.

# mock = fully offline, in-memory AWS mocks (default). aws = real boto3 clients.
POLYPHEMUS_MODE=mock

# AWS region (only used when POLYPHEMUS_MODE=aws)
POLYPHEMUS_REGION=us-east-1

# Bedrock model ids (referenced by the mock; used for real invocation in aws mode)
POLYPHEMUS_BEDROCK_TEXT_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0
POLYPHEMUS_BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0

# Vector store backend: opensearch (primary) | pgvector (documented alternate)
POLYPHEMUS_VECTOR_BACKEND=opensearch

# Storage / index names (placeholders — no real endpoints)
POLYPHEMUS_DOCUMENTS_BUCKET=polyphemus-documents-REPLACE_ME
POLYPHEMUS_INDEX_NAME=polyphemus-chunks

# Retrieval tuning
POLYPHEMUS_TOP_K=5
POLYPHEMUS_SIMILARITY_FLOOR=0.05
